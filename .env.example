# Public (embedded in client bundle)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# If the app and API share one origin (Vercel), leave empty.
# If API is elsewhere: VITE_API_BASE=https://your-api.example.com
# VITE_API_BASE=

# Local dev: proxy targets this for /api (run in another terminal: npx vercel dev)
# VITE_VERCEL_DEV_URL=http://127.0.0.1:3000

# Set ONLY in Vercel project env / server (never VITE_*)
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
